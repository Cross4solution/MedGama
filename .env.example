# ╔══════════════════════════════════════════════════════════════════╗
# ║  MedaGama — Frontend Environment Variables                      ║
# ║  Copy this file to .env and fill in the values.                ║
# ║  For production, set these in your hosting provider's env UI   ║
# ║  (Netlify / Vercel / etc.) — never commit .env to git.        ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── API Configuration ──
# Local dev:   http://127.0.0.1:8001/api
# Production:  /api  (proxied through Vercel → Railway, no CORS needed)
REACT_APP_API_BASE=http://127.0.0.1:8001/api

# Auth endpoint (default: /api/auth/me)
REACT_APP_API_ME=/api/auth/me

# Google Login endpoint (default: /api/login/google)
REACT_APP_API_LOGIN_GOOGLE=/api/login/google

# ── Real-time WebSocket (choose ONE: Pusher OR Reverb) ──

# Option A: Pusher (cloud) — recommended for production
# Get keys from https://dashboard.pusher.com
REACT_APP_PUSHER_APP_KEY=
REACT_APP_PUSHER_CLUSTER=eu

# Option B: Laravel Reverb (self-hosted) — for local dev or own infra
# Only set REACT_APP_REVERB_APP_KEY to activate Reverb mode
REACT_APP_REVERB_APP_KEY=
REACT_APP_REVERB_HOST=127.0.0.1
REACT_APP_REVERB_PORT=8080

# Legacy WS URL (unused — kept for backward compat)
REACT_APP_WS_URL=

# ── Google OAuth ──
REACT_APP_GOOGLE_CLIENT_ID=

# ── SEO ──
# Canonical site URL used in <link rel="canonical">, Open Graph, hreflang and JSON-LD.
# No trailing slash. Change this once the production domain is finalized.
REACT_APP_SITE_URL=https://medagama.com

# ── Analytics & Search Console (opsiyonel) ──
# Bu değişkenler set EDİLMEZSE ilgili script/meta HİÇ yüklenmez (güvenli, performanslı).
# Detaylı kurulum: tasks/seo-analytics-setup.md

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
# GA SADECE kullanıcı çerez banner'ında "analitik" onayı verince yüklenir (KVKK/GDPR).
NEXT_PUBLIC_GA_ID=

# Google Search Console — HTML tag doğrulama kodu.
# Search Console "HTML etiketi" yöntemindeki content="..." değerinin TAMAMI.
# Set edilince <meta name="google-site-verification"> otomatik eklenir.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Feature Flags ──
# Enable mock data fallback (true/false) — set false in production
REACT_APP_ENABLE_MOCK=false
